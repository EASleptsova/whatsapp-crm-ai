# ── Copy this file to .env and fill in your values ───────────────────────────
# cp .env.example .env

# ── AI Provider ──────────────────────────────────────────────────────────────
AI_PROVIDER=groq       # "claude" | "gemini" | "groq"

# ── Groq ─────────────────────────────────────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
# Note: free tier not available in EU countries
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.0-flash

# ── Twilio (WhatsApp) ─────────────────────────────────────────────────────────
# Sign up at https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── App ───────────────────────────────────────────────────────────────────────
BUSINESS_NAME=FarmFresh Boxes
BUSINESS_TIMEZONE=Europe/Lisbon
MOCK_MODE=true
DATABASE_PATH=crm.db

# ── Delivery ──────────────────────────────────────────────────────────────────
DELIVERY_LOCATIONS=Lisbon Downtown,Cascais,Sintra,Oeiras
PRICE_FRUITS=28.0
PRICE_VEGETABLES=24.0
PRICE_MIX=26.0

# ── Follow-ups ────────────────────────────────────────────────────────────────
FOLLOW_UP_DELAY_HOURS=24
REPEAT_CUSTOMER_DAYS=7
